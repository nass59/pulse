# --- Local working notes (issue tracker, PRDs, scratch) ---
.scratch/

# --- OS ---
.DS_Store
Thumbs.db

# --- Editors ---
.idea/
.vscode/
*.swp
*~

# --- Node (services/identity, tooling) ---
node_modules/
.env
.env.local
.env.*.local
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
**/dist/
**/.next/
**/out/
.turbo/
coverage/

