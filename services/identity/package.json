{
  "name": "@pulse/identity",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts | pino-pretty --colorize --translateTime 'SYS:HH:MM:ss.l' --ignore 'pid,hostname'",
    "start": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "migrate": "node-pg-migrate",
    "stage-event": "bun scripts/stage-event.ts",
    "consume": "bun scripts/consume.ts"
  },
  "dependencies": {
    "@kafkajs/confluent-schema-registry": "^4.1.0",
    "@pulse/schemas": "workspace:*",
    "fastify": "^5.8.5",
    "kafkajs": "^2.2.4",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
