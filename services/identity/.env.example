# Copy to .env for local dev. Values below match infra/docker-compose.yaml.

PORT=3000
DATABASE_URL=postgres://postgres:example@localhost:5432/pulse
KAFKA_BROKERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8080

# We intentionally use kafkajs's v2 (Java-compatible) default partitioner so
# channelId hashes to the same partition across our polyglot producers. This
# only silences the migration nag.
KAFKAJS_NO_PARTITIONER_WARNING=1
