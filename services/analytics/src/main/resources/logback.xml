<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} %-5level %logger{24} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Kafka's internals are chatty even at INFO; keep them at WARN so YOUR
       output is legible. Dial to INFO if you want to watch rebalances. -->
  <logger name="org.apache.kafka" level="WARN"/>
  <logger name="io.confluent.kafka.serializers" level="WARN"/>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
